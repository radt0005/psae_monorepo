# Database (Postgres)
DATABASE_URL=postgres://spade:spade@localhost:5432/spade

# Better Auth
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
NUXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=spade
S3_SECRET_ACCESS_KEY=spadespade
S3_BUCKET=spade

# Worker queue
RABBITMQ_URL=amqp://spade:spade@localhost:5672
RABBITMQ_QUEUE=user_submissions
# Shared secret the scheduler/worker presents (Authorization: Bearer ...)
# when PATCHing run status / posting result files back to the web UI.
WORKER_CALLBACK_SECRET=replace-me-with-a-long-random-string
