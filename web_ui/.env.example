# Database (Postgres)
DATABASE_URL=postgres://spade:spade@localhost:5432/spade

# Better Auth
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
NUXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=spade
S3_SECRET_ACCESS_KEY=spadespade
S3_BUCKET=spade

# Scheduler callback secret.
# The Go scheduler presents this as "Authorization: Bearer <secret>" when it
# calls PATCH /api/runs/:id to report run status, files, and logs back to the
# web UI.  Must match SPADE_UI_CALLBACK_SECRET in the scheduler's environment.
# RabbitMQ (spade.jobs / spade.results) is used only by the scheduler and
# workers — the web UI itself does not publish to or consume from the broker.
WORKER_CALLBACK_SECRET=replace-me-with-a-long-random-string
