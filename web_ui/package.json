{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bunx --bun nuxt build",
    "dev": "bunx --bun nuxt dev",
    "generate": "bunx --bun nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "bunx --bun nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "typecheck": "nuxt prepare && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "stack:up": "docker compose up -d --wait",
    "stack:down": "docker compose down",
    "stack:reset": "docker compose down -v && docker compose up -d --wait",
    "dev:up": "bun run stack:up && bun run db:migrate && bun run dev",
    "dev:reset": "bun run stack:reset && bun run db:migrate && bun run dev"
  },
  "dependencies": {
    "@formschema/native": "^2.0.0-beta.7",
    "@jsonforms/core": "^3.5.1",
    "@jsonforms/vue": "^3.5.1",
    "@jsonforms/vue-vanilla": "^3.5.1",
    "@jsonforms/vue-vuetify": "^3.5.1",
    "@koumoul/vjsf": "^3.12.0",
    "@nuxt/ui": "^2.18.4",
    "@nuxtjs/leaflet": "^1.2.0",
    "@pinia/nuxt": "^0.7.0",
    "@types/amqplib": "^0.10.7",
    "@types/uuid": "^10.0.0",
    "@vue-flow/core": "^1.39.3",
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "amqplib": "^0.10.7",
    "baseline-browser-mapping": "^2.10.34",
    "better-auth": "^1.6.6",
    "caniuse-lite": "^1.0.30001793",
    "csv-simple-parser": "^2.0.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^3.12.4",
    "postgres": "^3.4.9",
    "uuid": "^10.0.0",
    "vue": "latest"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@playwright/test": "^1.49.0",
    "@nuxtjs/supabase": "^1.3.5",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.9.0",
    "pg": "^8.20.0",
    "undici-types": "^7.8.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "std-env": "^4.0.0"
  }
}
